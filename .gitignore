.DS_Store
Thumbs.db

# App data
database/sqlite/*.db
data/hf_cache/
data/documents/
data/images/
data/uploads/
data/exports/
data/sandbox/

# Vector store data - never commit these
# Weaviate: had RAFT state committed accidentally; untrack with:
#   git rm -r --cached database/weaviate/
database/weaviate/

# Qdrant
database/qdrant/

# Logs
*.log
logs/

# Test artifacts
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage

# Model weights - never commit GGUF files
models/**/*.gguf
models/**/*.gguf.part

# bin contents are too large for git
bin/*
!bin/.gitkeep

# Environment files - never commit secrets
.env
