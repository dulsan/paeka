# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environment (UV)
.venv/
# [FIX] uv.lock was gitignored, meaning native and Docker builds could
# (and did) silently resolve different dependency versions from each
# other -- see the transformers<5 comment in pyproject.toml for the bug
# that caused. Committing the lockfile is what actually prevents this
# class of problem recurring; the version pin alone only fixes today's
# instance of it.

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# App data
database/sqlite/*.db
data/hf_cache/
data/documents/
data/images/
data/uploads/
data/exports/
data/sandbox/

# Vector store data - never commit these
# Weaviate: had RAFT state committed accidentally; untrack with:
#   git rm -r --cached database/weaviate/
database/weaviate/

# Qdrant
database/qdrant/

# Logs
*.log
logs/

# Test artifacts
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage

# Model weights - never commit GGUF files
models/**/*.gguf
models/**/*.gguf.part

# bin contents are too large for git
bin/*
!bin/.gitkeep

# Environment files - never commit secrets
.env
