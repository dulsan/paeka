# =============================================================================
# PAEKA .env - copy to .env and edit
# NEVER commit .env to git
# =============================================================================

# -- LLM: Ollama --------------------------------------------------------------
PAEKA_LLM__PROVIDER=ollama
PAEKA_LLM__BASE_URL=http://localhost:11434/v1
PAEKA_LLM__API_KEY=ollama
PAEKA_LLM__MODEL=paeka-qwen

# -- Vector store: Qdrant -----------------------------------------------------
# Native: bin\qdrant.exe (see config/qdrant.yaml)
# Docker: leave this as-is -- docker-compose.yml overrides it to the
#         paeka-qdrant service name for you automatically.
PAEKA_RETRIEVAL__QDRANT_URL=http://localhost:6333
PAEKA_RETRIEVAL__ENABLED=true
PAEKA_RETRIEVAL__EMBED_DEVICE=cpu
PAEKA_RETRIEVAL__RERANKER_DEVICE=cpu

# -- HuggingFace ---------------------------------------------------------------
# Optional token for faster downloads (no rate limiting)
# Get one free at https://huggingface.co/settings/tokens
# HF_TOKEN=hf_your_token_here
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# -- Security - off for local dev ---------------------------------------------
PAEKA_SECURITY__ENABLED=false
PAEKA_SECURITY__TOKEN=

# -- Web search - off by default (DuckDuckGo, no API key needed) --------------
PAEKA_TOOLS__WEB_SEARCH_ENABLED=false
