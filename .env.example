# =============================================================================
# PAEKA .env - copy to .env and edit
# NEVER commit .env to git
# =============================================================================

# LLM
PAEKA_LLM__MODEL=Qwen3.5-9B-Q4_K_M
PAEKA_LLM__MODEL_PATH=models\qwen\Qwen3.5-9B-Q4_K_M.gguf

# Weaviate (Docker, mapped to localhost:8090)
PAEKA_RETRIEVAL__WEAVIATE_URL=http://localhost:8090

# Retrieval - set true after first clean start
PAEKA_RETRIEVAL__ENABLED=true

# CPU for embeddings (torch CPU wheel installed - CUDA embeddings not available)
PAEKA_RETRIEVAL__EMBED_DEVICE=cpu
PAEKA_RETRIEVAL__RERANKER_DEVICE=cpu

# HuggingFace - optional token for faster downloads (no rate limiting)
# Get one free at https://huggingface.co/settings/tokens
# HF_TOKEN=hf_your_token_here
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# Security - off for local dev
PAEKA_SECURITY__ENABLED=false
PAEKA_SECURITY__TOKEN=

# Web search - off by default (DuckDuckGo, no API key needed)
PAEKA_TOOLS__WEB_SEARCH_ENABLED=false
