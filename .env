# =============================================================================
# PAEKA — Native Windows deployment environment
# Copy to project root as .env  (never commit this file)
# =============================================================================

# ----------------------------------------------------------------------------
# Deployment mode
# ----------------------------------------------------------------------------
PAEKA_DEPLOY_MODE=development
PAEKA_DOMAIN=localhost

# ----------------------------------------------------------------------------
# LLM — llama-server runs natively via start.ps1, NOT in Docker
# ----------------------------------------------------------------------------
PAEKA_LLM__PROVIDER=llama_cpp
PAEKA_LLM__BASE_URL=http://localhost:8080/v1
PAEKA_LLM__API_KEY=paeka-local
PAEKA_LLM__MODEL=Qwen3.5-9B-Q4_K_M
PAEKA_LLM__MODEL_PATH=models\qwen\Qwen3.5-9B-Q4_K_M.gguf
PAEKA_LLM__MAX_TOKENS=4096
PAEKA_LLM__REQUEST_TIMEOUT=180

# ----------------------------------------------------------------------------
# Weaviate — Docker container exposed on host port 8090
#   (internal container port 8080 → host 8090 to avoid clash with llama-server)
# ----------------------------------------------------------------------------
PAEKA_RETRIEVAL__WEAVIATE_URL=http://localhost:8090
PAEKA_RETRIEVAL__ENABLED=true

# ----------------------------------------------------------------------------
# Embedding / reranking device
#
# DEFAULT: cpu  — torch is installed as a CPU-only wheel (safe for 8 GB GPU
#                 almost fully occupied by the 9B Q4_K_M model ~5.9 GB).
#
# TO ENABLE CUDA EMBEDDINGS:
#   1. Reinstall torch with CUDA 12.8 wheels (≈2.4 GB download):
#        uv pip install torch torchvision --index-url https://download.pytorch.org/whl/cu128
#      OR edit pyproject.toml — replace the [tool.uv.sources] block with:
#        [tool.uv.sources]
#        torch       = { index = "pytorch-cu128" }
#        torchvision = { index = "pytorch-cu128" }
#        [[tool.uv.index]]
#        name = "pytorch-cu128"
#        url  = "https://download.pytorch.org/whl/cu128"
#        explicit = true
#      then: uv sync --reinstall
#   2. Change the two lines below from "cpu" to "cuda"
#   3. Verify VRAM headroom: model ~5.9 GB + bge-m3 ~1.2 GB + reranker ~0.5 GB
#      Total ≈ 7.6 GB — fits in 8 GB but leaves very little margin.
# ----------------------------------------------------------------------------
PAEKA_RETRIEVAL__EMBED_DEVICE=cpu
PAEKA_RETRIEVAL__RERANKER_DEVICE=cpu
PAEKA_RETRIEVAL__EMBED_MODEL=BAAI/bge-m3
PAEKA_RETRIEVAL__RERANKER_MODEL=BAAI/bge-reranker-large

# ----------------------------------------------------------------------------
# HuggingFace Hub
# No HF_TOKEN needed for public models (bge-m3, bge-reranker-large).
# The lines below suppress the "unauthenticated request" warning and the
# Windows symlink warning that appear on first model download.
# ----------------------------------------------------------------------------
HF_HUB_DISABLE_SYMLINKS_WARNING=1
HF_HUB_VERBOSITY=error
TOKENIZERS_PARALLELISM=false
TRANSFORMERS_NO_ADVISORY_WARNINGS=true

# ----------------------------------------------------------------------------
# Security — off for localhost development
# ----------------------------------------------------------------------------
PAEKA_SECURITY__ENABLED=false
PAEKA_SECURITY__TOKEN=
PAEKA_SECURITY__RATE_LIMIT_ENABLED=false
PAEKA_SECURITY__CONTENT_SCAN_ENABLED=true
PAEKA_SECURITY__STRICT_MODE=false

# ----------------------------------------------------------------------------
# Web search — off by default; set to true once SearXNG is running
# ----------------------------------------------------------------------------
PAEKA_TOOLS__WEB_SEARCH_ENABLED=false
PAEKA_TOOLS__SEARXNG_URL=http://localhost:8888

# ----------------------------------------------------------------------------
# Knowledge graph — off by default (expensive; enable after RAG is stable)
# ----------------------------------------------------------------------------
PAEKA_KNOWLEDGE_GRAPH__ENABLED=false

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
PAEKA_LOGGING__LEVEL=INFO
PAEKA_LOGGING__FORMAT=rich
