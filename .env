# =============================================================================
# PAEKA .env - loaded by start_fixed.ps1 before any Python process starts
# Never commit this file to git (it is in .gitignore)
# =============================================================================

# -- LLM: Ollama --------------------------------------------------------------
# Ollama serves an OpenAI-compatible API at localhost:11434/v1
# Install: https://ollama.com/download/windows
# Import model: ollama create paeka-qwen -f models\qwen\Modelfile
# Or pull: ollama pull qwen3:9b  (re-downloads ~5.5GB)
PAEKA_LLM__PROVIDER=ollama
PAEKA_LLM__BASE_URL=http://localhost:11434/v1
PAEKA_LLM__API_KEY=ollama
PAEKA_LLM__MODEL=paeka-qwen
PAEKA_LLM__MAX_TOKENS=4096
PAEKA_LLM__TEMPERATURE=0.7
PAEKA_LLM__REQUEST_TIMEOUT=180

# -- Vector store: Qdrant -----------------------------------------------------
# Download qdrant.exe: https://github.com/qdrant/qdrant/releases
# Look for: qdrant-x86_64-pc-windows-msvc.zip -> extract to bin\qdrant.exe
# Config: config\qdrant.yaml
# Qdrant starts automatically via start_fixed.ps1
PAEKA_RETRIEVAL__QDRANT_URL=http://localhost:6333
PAEKA_RETRIEVAL__ENABLED=true
PAEKA_RETRIEVAL__EMBED_DEVICE=cpu
PAEKA_RETRIEVAL__RERANKER_DEVICE=cpu
PAEKA_RETRIEVAL__EMBED_MODEL=BAAI/bge-m3
PAEKA_RETRIEVAL__RERANKER_MODEL=BAAI/bge-reranker-large

# -- HuggingFace Hub ----------------------------------------------------------
# Public models (bge-m3, bge-reranker-large) do not require authentication.
# These are set here so they are in the process environment before Python starts.
HF_HUB_DISABLE_SYMLINKS_WARNING=1
HF_HUB_VERBOSITY=error
# [FIX] Suppresses the "Loading weights: 100%|...|" tqdm bars shown during
# embedder/reranker startup -- confirmed via HF's own docs as the single,
# comprehensive switch covering transformers, sentence-transformers, and
# huggingface_hub all at once (they all route through the same tqdm
# wrapper). Quiet, consistent startup logs are easier to scan than a
# progress bar that doesn't add information once you already know the
# model loaded (the INFO line right after it already confirms that).
HF_HUB_DISABLE_PROGRESS_BARS=1
TOKENIZERS_PARALLELISM=false

# -- OpenTelemetry / Logfire httpx tracing ------------------------------------
# Excludes one-time HuggingFace Hub model-download housekeeping traffic
# (dozens of HEAD requests probing for files that don't exist for bge-m3)
# from the httpx trace, so it doesn't bury the actually-useful Ollama/MCP/
# Qdrant traces under noise on every cold start.
#
# This is an environment variable, not a function parameter -- confirmed
# directly against opentelemetry-instrumentation-httpx's own source
# (HTTPXClientInstrumentor.instrument() has no excluded_urls kwarg at all;
# exclusion is read from OTEL_PYTHON_HTTPX_EXCLUDED_URLS, or the broader
# OTEL_PYTHON_EXCLUDED_URLS, at instrument-time). A previous attempt passed
# excluded_urls= directly to logfire.instrument_httpx() -- that was wrong;
# the kwarg is silently accepted by logfire's wrapper but has no effect,
# which is exactly why the huggingface.co traffic kept appearing despite
# the fix being "applied".
OTEL_PYTHON_HTTPX_EXCLUDED_URLS=huggingface\.co,raw\.githubusercontent\.com

# -- Security -----------------------------------------------------------------
PAEKA_SECURITY__ENABLED=false
PAEKA_SECURITY__TOKEN=
PAEKA_SECURITY__RATE_LIMIT_ENABLED=false
PAEKA_SECURITY__CONTENT_SCAN_ENABLED=true
PAEKA_SECURITY__STRICT_MODE=false

# -- Web search ---------------------------------------------------------------
PAEKA_TOOLS__WEB_SEARCH_ENABLED=false
PAEKA_TOOLS__SEARXNG_URL=http://localhost:8888

# -- Deployment ---------------------------------------------------------------
PAEKA_DEPLOY_MODE=development
