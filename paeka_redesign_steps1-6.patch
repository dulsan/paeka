-      # sandbox actually uses -- POST is a blanket write-toggle, still
-      # scoped per-category below it, so POST+CONTAINERS+IMAGES together
-      # means "may create/start containers and pull images", nothing more.
-      CONTAINERS: "1"     # create/start/stop/remove containers, inspect
-      IMAGES: "1"          # pull/inspect the python/alpine/node sandbox images
-      INFO: "1"            # `docker info` -- is_available() + runtime detection
-      POST: "1"
-      # Explicitly off: each of these is a real privilege-escalation path
-      # if left open to a process that might get compromised. EXEC alone
-      # would let a compromised paeka-api run arbitrary commands inside
-      # *any* running container, e.g. paeka-qdrant/paeka-ollama.
-      EXEC: "0"
-      VOLUMES: "0"         # sandbox_scratch is referenced by name inside a
-                            # CONTAINERS create call, not via the /volumes API
-      NETWORKS: "0"
-      SWARM: "0"
-      SERVICES: "0"
-      TASKS: "0"
-      NODES: "0"
-      PLUGINS: "0"
-      BUILD: "0"           # separate gate from IMAGES -- building from an
-                            # arbitrary Dockerfile is its own risk category
-      COMMIT: "0"          # separate gate from CONTAINERS -- snapshotting a
-                            # running container into a new image
-      SECRETS: "0"
-      CONFIGS: "0"
-      DISTRIBUTION: "0"
-      AUTH: "0"
-      SESSION: "0"
-    volumes:
-      - /var/run/docker.sock:/var/run/docker.sock:ro
-    # No healthcheck here -- this image is Alpine/HAProxy-based and I'm
-    # not confident it ships a shell capable of the bash /dev/tcp trick
-    # used for paeka-qdrant below, and would rather skip a healthcheck
-    # than ship one I can't verify actually passes. depends_on below
-    # only waits for the process to start, not for it to be ready --
-    # if paeka-api logs connection-refused on its first sandbox check,
-    # that's why; it should resolve on the next health probe.
-
-  paeka-qdrant:
-    image: qdrant/qdrant:v1.18.2-unprivileged
-    container_name: paeka-qdrant
-    restart: unless-stopped
-    environment:
-      QDRANT__TELEMETRY_DISABLED: "true"
-      QDRANT__SERVICE__MAX_REQUEST_SIZE_MB: "256"
-    volumes:
-      - qdrant_storage:/qdrant/storage
-    ports:
-      - "127.0.0.1:6333:6333"   # REST + dashboard (http://localhost:6333/dashboard)
-      - "127.0.0.1:6334:6334"   # gRPC
-    healthcheck:
-      # qdrant/qdrant deliberately ships without curl/wget (a security
-      # decision upstream, see qdrant/qdrant#3491 and #4250) -- a bare TCP
-      # check via bash's /dev/tcp needs nothing extra installed.
-      test: ["CMD-SHELL", "bash -c 'exec 3<>/dev/tcp/127.0.0.1/6333' || exit 1"]
-      interval: 10s
-      timeout: 5s
-      retries: 10
-      start_period: 15s
-
-  paeka-ollama:
-    image: ollama/ollama:latest
-    container_name: paeka-ollama
-    restart: unless-stopped
-    environment:
-      OLLAMA_HOST: "0.0.0.0:11434"
-      # 9B model fully offloaded to GPU (see models/qwen/Modelfile,
-      # num_gpu 99) -- cap parallel requests to avoid CUDA OOM on a single
-      # GPU. Raise this if your card has headroom to spare.
-      OLLAMA_NUM_PARALLEL: "1"
-    volumes:
-      - ollama_data:/root/.ollama
-      - ./models/qwen:/models/qwen:ro
-    # No host port published on purpose: paeka-api reaches this over the
-    # internal Docker network at http://paeka-ollama:11434, so exposing
-    # 11434 to the host isn't needed -- and doing so collides with a
-    # native Ollama install, which commonly auto-starts as a background/
-    # tray service on Windows and never lets go of that port. If you want
-    # host-side access too (e.g. to `curl localhost:11435/api/tags` or
-    # point a native `ollama` CLI at this container), first make sure
-    # nothing native already owns whichever port you pick, then add:
-    #   ports:
-    #     - "127.0.0.1:11435:11434"
-    deploy:
-      resources:
-        reservations:
-          devices:
-            - driver: nvidia
-              count: 1
-              capabilities: [gpu]
-    healthcheck:
-      # Uses the ollama binary already in the image -- no curl/wget needed.
-      test: ["CMD", "ollama", "list"]
-      interval: 10s
-      timeout: 5s
-      retries: 10
-      start_period: 20s
-
-  paeka-ollama-init:
-    image: ollama/ollama:latest
-    container_name: paeka-ollama-init
-    restart: "no"
-    depends_on:
-      paeka-ollama:
-        condition: service_healthy
-    environment:
-      OLLAMA_HOST: "paeka-ollama:11434"
-    volumes:
-      - ./models/qwen:/models/qwen:ro
-    entrypoint: ["ollama"]
-    # `ollama create` overwrites an existing model of the same name, so
-    # re-running this on every `up` is safe and picks up Modelfile edits.
-    command: ["create", "paeka-qwen", "-f", "/models/qwen/Modelfile"]
-
-  paeka-api:
-    build:
-      context: .
-      dockerfile: Dockerfile
-    container_name: paeka-api
-    restart: unless-stopped
-    depends_on:
-      paeka-qdrant:
-        condition: service_healthy
-      paeka-ollama-init:
-        condition: service_completed_successfully
-      docker-socket-proxy:
-        condition: service_started
-    env_file:
-      - .env
-    environment:
-      # Overrides for container networking -- everything else in .env
-      # (security, HF hub, OTEL, etc.) still applies as-is.
-      PAEKA_LLM__BASE_URL: "http://paeka-ollama:11434/v1"
-      PAEKA_RETRIEVAL__QDRANT_URL: "http://paeka-qdrant:6333"
-      # [FIX] execute_code had no way to reach a Docker daemon at all
-      # from inside this container -- see SETUP_DOCKER.md section 4.
-      # DOCKER_HOST points the `docker` CLI at the socket-proxy sidecar
-      # (a scoped slice of the real API), never at a raw socket mounted
-      # directly into this container.
-      DOCKER_HOST: "tcp://docker-socket-proxy:2375"
-      # Paired with the sandbox_scratch volume below: lets the sandbox
-      # write scripts somewhere a *sibling* container (spun up via the
-      # proxy, not a child of this one) can actually see -- this
-      # container's own /tmp isn't visible to the real Docker host.
-      # Referenced by volume *name* (pinned below), not path -- works
-      # the same on Windows/WSL2/Linux. See backend/agent/sandbox.py's
-      # module docstring for why this is necessary at all.
-      PAEKA_SANDBOX__SCRATCH_DIR: "/app/sandbox_scratch"
-      PAEKA_SANDBOX__SCRATCH_VOLUME: "paeka_sandbox_scratch"
-    volumes:
-      - paeka_data:/app/data
-      - paeka_database:/app/database
-      - ./models:/app/models:ro
-      - sandbox_scratch:/app/sandbox_scratch
-    ports:
-      - "8000:8000"
-
-volumes:
-  qdrant_storage:
-  ollama_data:
-  paeka_data:
-  paeka_database:
-  # Name pinned explicitly rather than left to Compose's default
-  # <project>_<volume> prefixing -- the sibling `docker run -v
-  # NAME:/sandbox:ro` call in backend/agent/sandbox.py is a raw Docker
-  # CLI invocation, outside Compose entirely, so it needs the *exact*
-  # on-engine name. If this were left unpinned and ever drifted from
-  # PAEKA_SANDBOX__SCRATCH_VOLUME above (e.g. someone renames this
-  # project's directory, which changes Compose's default prefix), the
-  # mismatch wouldn't error -- Docker auto-creates a volume that doesn't
-  # exist yet, so the sandbox would silently start writing into a fresh,
-  # disconnected, empty volume instead. Pinning the name removes that
-  # failure mode entirely.
-  sandbox_scratch:
-    name: paeka_sandbox_scratch
